{
    "name": "mbarky/laravel-network-ngenius",
    "description": "Laravel package for the N-Genius Online payment gateway by Network International (HPP flow).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "M. Barky",
            "email": "mbarky@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0",
        "illuminate/cache": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^2.0 || ^3.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.10 || ^2.0",
        "larastan/larastan": "^2.0 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "mbarky\\Ngenius\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mbarky\\Ngenius\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "mbarky\\Ngenius\\NgeniusServiceProvider"
            ],
            "aliases": {
                "Ngenius": "mbarky\\Ngenius\\Facades\\Ngenius"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
